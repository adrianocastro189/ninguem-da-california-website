---
import { site } from '../../data/site';
import { embedUrl, ytId } from '../../lib/youtube';

// Featured video embed, empty string when site.featuredVideo is blank.
const featured = embedUrl(ytId(site.featuredVideo));

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const logoWhite = `${base}/assets/logo-white.png`;
---

<header id="topo">
  <div class="rec">▸ REC ● 90s — 2000s ROCK</div>
  <img class="logo" src={logoWhite} alt="Ninguém da Califórnia" />
  <p class="lead">
    Rock dos anos 90 e 2000 com foco nos lados B de Nirvana, Foo Fighters, Muse,
    Radiohead, Queens of the Stone Age, Coldplay e muito mais.
  </p>
  <div class="actions">
    <a class="ndc-cbtn cbtn-primary" href="#contato">Contratar a banda</a>
    <a class="ndc-cbtn cbtn-ghost" href="#videos">Assistir</a>
  </div>

  <div class="featured">
    <div class="play"><span class="play-mark">■</span> PLAY ▸ DESTAQUE</div>
    <div class="frame">
      {
        featured && (
          <iframe
            src={featured}
            title="Vídeo destaque"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          />
        )
      }
    </div>
  </div>
</header>

<style>
  header {
    position: relative;
    max-width: var(--container-1180);
    margin: 0 auto;
    padding: var(--space-130) var(--space-22) var(--space-70);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .rec {
    margin-bottom: var(--space-10);
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: var(--fs-20);
    letter-spacing: var(--ls-30);
  }

  .logo {
    width: var(--w-logo-hero);
    height: auto;
    filter: var(--filter-logo-hero);
  }

  .lead {
    max-width: var(--container-620);
    margin: var(--space-14) auto var(--space-30);
    color: var(--color-text-muted);
    font-size: var(--fs-hero-lead);
    font-weight: 300;
    line-height: var(--lh-hero);
  }

  .actions {
    display: flex;
    gap: var(--space-14);
    flex-wrap: wrap;
    justify-content: center;
  }

  .ndc-cbtn {
    padding: var(--space-13) var(--space-26);
    font-family: var(--font-body);
    font-size: var(--fs-14);
    font-weight: 600;
    letter-spacing: var(--ls-12);
    text-transform: uppercase;
    text-decoration: none;
    transition: all var(--dur-base);
  }

  .cbtn-primary {
    color: var(--color-bg);
    background: var(--color-accent);
  }

  .cbtn-ghost {
    color: var(--color-text);
    background: transparent;
    border: var(--border-1) solid var(--color-line-25);
  }

  .featured {
    width: 100%;
    max-width: var(--container-920);
    margin-top: var(--space-48);
  }

  .play {
    display: flex;
    align-items: center;
    gap: var(--space-10);
    margin-bottom: var(--space-10);
    color: var(--color-text-dim);
    font-family: var(--font-mono);
    font-size: var(--fs-18);
    letter-spacing: var(--ls-18);
  }

  .play-mark {
    color: var(--color-accent);
  }

  .frame {
    position: relative;
    width: 100%;
    aspect-ratio: var(--ratio-video);
    background: var(--color-black);
    border: var(--border-1) solid var(--color-line-strong);
    box-shadow: var(--shadow-video);
  }

  .frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
