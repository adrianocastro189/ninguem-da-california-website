---
import SectionHeading from '../ui/SectionHeading.astro';
import { site } from '../../data/site';
---

<section id="historia">
  <SectionHeading index="01" kicker="A BANDA" title="Breve história" />
  <p>{site.history}</p>
</section>

<style>
  section {
    position: relative;
    max-width: var(--container-1000);
    margin: 0 auto;
    padding: var(--space-80) var(--space-22);
  }

  /* margin-top recreates the prototype's h2 bottom gap (24px) now that the
     shared heading carries no bottom margin. */
  p {
    margin-top: var(--space-24);
    max-width: var(--container-760);
    color: var(--color-text-muted);
    font-size: var(--fs-history);
    font-weight: 300;
    line-height: var(--lh-prose);
  }
</style>
