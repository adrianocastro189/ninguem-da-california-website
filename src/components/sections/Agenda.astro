---
import SectionHeading from '../ui/SectionHeading.astro';
import { site } from '../../data/site';
import { dateLabel } from '../../lib/format';

const hasShows = site.shows.length > 0;
---

<section id="agenda">
  <SectionHeading index="06" kicker="AGENDA" title="Próximos shows" />
  {
    hasShows ? (
      <div class="list">
        {site.shows.map((show) => (
          <div class="show">
            <div class="date">{dateLabel(show.date)}</div>
            <div class="info">
              <div class="venue">{show.venue}</div>
              <div class="citytime">
                {show.city} · {show.time}
              </div>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="nosignal">
        <div class="ns-title">— NO SIGNAL —</div>
        <div class="ns-lead">Nenhum show marcado no momento.</div>
        <div class="ns-cta">
          Quer trazer a Ninguém da Califórnia pro seu palco?{' '}
          <a href="#contato">Fale com a gente.</a>
        </div>
      </div>
    )
  }
</section>

<style>
  section {
    position: relative;
    max-width: var(--container-1000);
    margin: 0 auto;
    padding: var(--space-70) var(--space-22) var(--space-90);
  }

  /* margin-top recreates the prototype's h2 bottom gap (30px). */
  .list,
  .nosignal {
    margin-top: var(--space-30);
  }

  .list {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  .show {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-20);
    padding: var(--space-18) var(--space-20);
    background: var(--color-line-03);
    border-left: var(--border-3) solid var(--color-accent);
  }

  .date {
    min-width: var(--min-show-date);
    color: var(--color-white);
    font-family: var(--font-display);
    font-size: var(--fs-22);
  }

  .info {
    flex: 1;
    min-width: var(--min-show-info);
  }

  .venue {
    color: var(--color-rep-title);
    font-family: var(--font-body);
    font-size: var(--fs-18);
    font-weight: 600;
  }

  .citytime {
    color: var(--color-text-dim);
    font-size: var(--fs-14);
  }

  .nosignal {
    padding: var(--space-50) var(--space-24);
    border: var(--border-1) dashed var(--color-line-20);
    background: var(--stripe-agenda);
    text-align: center;
  }

  .ns-title {
    margin-bottom: var(--space-8);
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: var(--fs-26);
    letter-spacing: var(--ls-10);
  }

  .ns-lead {
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: var(--fs-18);
    font-weight: 300;
  }

  .ns-cta {
    margin-top: var(--space-6);
    color: var(--color-text-faint);
    font-family: var(--font-body);
    font-size: var(--fs-15);
    font-weight: 300;
  }

  .ns-cta a {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: var(--border-1) solid var(--color-accent);
  }
</style>
