---
import SectionHeading from '../ui/SectionHeading.astro';
import CarouselArrow from '../ui/CarouselArrow.astro';
import { site } from '../../data/site';
import { embedUrl, ytId } from '../../lib/youtube';

// Nocookie embeds for every valid short; empties dropped.
const shortEmbeds = site.shorts.map((s) => embedUrl(ytId(s))).filter(Boolean);
const hasShorts = shortEmbeds.length > 0;
const count = shortEmbeds.length || 1;
---

<section id="videos">
  <SectionHeading index="04" kicker="SHORTS" title="No YouTube" />
  <div
    class="row"
    x-data={`{ i: 0, n: ${count}, embeds: ${JSON.stringify(shortEmbeds)}, prev() { this.i = (this.i - 1 + this.n) % this.n }, next() { this.i = (this.i + 1) % this.n } }`}
  >
    <CarouselArrow dir="prev" click="prev()" />
    <div class="player">
      {
        hasShorts && (
          <iframe
            x-bind:src="embeds[i]"
            title="Short"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          />
        )
      }
    </div>
    <CarouselArrow dir="next" click="next()" />
  </div>
  {
    hasShorts ? (
      <div
        class="counter"
        x-text="String(i + 1).padStart(2, '0') + ' / ' + String(n).padStart(2, '0')"
      />
    ) : (
      <div class="counter">—</div>
    )
  }
</section>

<style>
  section {
    position: relative;
    max-width: var(--container-1080);
    margin: 0 auto;
    padding: var(--space-70) var(--space-22) var(--space-90);
  }

  /* margin-top recreates the prototype's h2 bottom gap (30px). */
  .row {
    margin-top: var(--space-30);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-18);
  }

  .player {
    position: relative;
    width: var(--w-short);
    aspect-ratio: var(--ratio-short);
    background: var(--color-black);
    border: var(--border-1) solid var(--color-line-strong);
    box-shadow: var(--shadow-video);
  }

  .player iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .counter {
    margin-top: var(--space-14);
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: var(--fs-18);
    letter-spacing: var(--ls-15);
    text-align: center;
  }
</style>
