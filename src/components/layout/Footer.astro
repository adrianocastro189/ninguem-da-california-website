---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const logoWhite = `${base}/assets/logo-white.png`;
const pressKitUrl = `${base}/assets/presskit.pdf`;
const privacyUrl = `${base}/privacidade`;
const year = new Date().getFullYear();
---

<footer>
  <img class="logo" src={logoWhite} alt="Ninguém da Califórnia" />
  <div class="copy">
    © {year} NINGUÉM DA CALIFÓRNIA · TODOS OS DIREITOS RESERVADOS
  </div>
  <div class="links">
    <a class="privacy" href={privacyUrl}>Política de privacidade</a>
    <a class="privacy" href={pressKitUrl}>Press kit</a>
  </div>
</footer>

<style>
  footer {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-14);
    padding: var(--space-36) var(--space-22);
    border-top: var(--border-1) solid var(--color-line);
  }

  .logo {
    height: var(--w-logo-footer);
    width: auto;
    opacity: 0.85;
  }

  .copy {
    color: var(--color-footer);
    font-family: var(--font-mono);
    font-size: var(--fs-17);
    letter-spacing: var(--ls-12);
    text-align: center;
  }

  .links {
    display: flex;
    align-items: center;
    gap: var(--space-14);
  }

  .privacy {
    color: var(--color-footer);
    font-family: var(--font-mono);
    font-size: var(--fs-13);
    letter-spacing: var(--ls-12);
    text-decoration: none;
    text-transform: uppercase;
  }

  .privacy:hover {
    color: var(--color-accent);
  }
</style>
